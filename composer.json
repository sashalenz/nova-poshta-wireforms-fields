{
    "name": "sashalenz/nova-poshta-wireforms-fields",
    "description": "This is my package nova-poshta-wireforms-fields",
    "keywords": [
        "sashalenz",
        "laravel",
        "nova-poshta-wireforms-fields"
    ],
    "homepage": "https://github.com/sashalenz/nova-poshta-wireforms-fields",
    "license": "MIT",
    "authors": [
        {
            "name": "Oleksandr Petrovskyi",
            "email": "sashalenz@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^9.0",
        "sashalenz/nova-poshta-api": "^1.5",
        "sashalenz/wireforms": "^0.2.12",
        "spatie/laravel-package-tools": "^1.13.0"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^6.0",
        "nunomaduro/larastan": "^2.0.1",
        "orchestra/testbench": "^7.0",
        "pestphp/pest": "^1.21",
        "pestphp/pest-plugin-laravel": "^1.1",
        "phpstan/extension-installer": "^1.1",
        "phpstan/phpstan-deprecation-rules": "^1.0",
        "phpstan/phpstan-phpunit": "^1.0",
        "phpunit/phpunit": "^9.5"
    },
    "autoload": {
        "psr-4": {
            "Sashalenz\\NovaPoshtaWireformsFields\\": "src",
            "Sashalenz\\NovaPoshtaWireformsFields\\Database\\Factories\\": "database/factories"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sashalenz\\NovaPoshtaWireformsFields\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Sashalenz\\NovaPoshtaWireformsFields\\NovaPoshtaWireformsFieldsServiceProvider"
            ],
            "aliases": {
                "NovaPoshtaWireformsFields": "Sashalenz\\NovaPoshtaWireformsFields\\Facades\\NovaPoshtaWireformsFields"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
